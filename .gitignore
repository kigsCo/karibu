# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
dist-ssr/
*.local

# Environment — never commit real secrets
.env
.env.*
!.env.example
# .env.production is the exception: it holds ONLY the two PUBLIC Vite values
# (VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY) so the Vercel build points at the
# cloud project. Both ship in the browser bundle by design — no secret here.
!.env.production

# Supabase local
supabase/.branches
supabase/.temp
supabase/.env

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Claude Code local settings (keep shared settings.json; ignore personal overrides)
.claude/settings.local.json
