# Karibu frontend environment — copy to .env and fill in.
# ONLY public values belong here. They ship in the browser bundle.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# Optional client-side analytics
VITE_PLAUSIBLE_DOMAIN=karibu.co.ke

# ---------------------------------------------------------------------------
# DO NOT PUT THESE HERE. They are Supabase Edge Function secrets, set via:
#   Supabase Dashboard -> Settings -> Edge Functions -> Secrets
# Putting any of these in a VITE_* var leaks them into the browser.
#
#   ANTHROPIC_API_KEY        (sk-ant-...)   read only by ask-karibu / moderate-reviews
#   SUPABASE_SERVICE_ROLE_KEY               server-only; never in the frontend
#   MPESA_CONSUMER_KEY  MPESA_CONSUMER_SECRET  MPESA_PASSKEY
#   MPESA_CALLBACK_SECRET                   REQUIRED. High-entropy random string
#                                           (e.g. `openssl rand -hex 32`). It is
#                                           how mpesa-callback tells Safaricom
#                                           apart from anyone else who finds the
#                                           URL. Without it, mpesa-stk-push
#                                           refuses to start a payment and
#                                           mpesa-callback returns 503.
#   MPESA_CALLBACK_URL       (optional)     override the callback base URL. The
#                                           secret is appended automatically —
#                                           do not hardcode it here.
#   RESEND_API_KEY           (re_...)       transactional email
#   SENTRY_DSN                              error tracking
# ---------------------------------------------------------------------------
